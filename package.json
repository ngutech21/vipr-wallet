{
  "name": "vipr",
  "version": "0.0.1",
  "description": "Fedimint eCash Wallet",
  "productName": "Vipr Wallet",
  "author": "ngutech21 <ngutech21@pm.me>",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint -c ./eslint.config.js \"{src,test}/**/*.{ts,js,cjs,mjs,vue}\" --max-warnings 0",
    "lint:fix": "eslint -c ./eslint.config.js \"{src,test}/**/*.{ts,js,cjs,mjs,vue}\" --fix --max-warnings 0",
    "format": "prettier --write \"**/*.{js,ts,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "test": "pnpm run test:unit:ci",
    "dev": "quasar dev -m pwa",
    "dev:e2e": "BROWSER=none quasar dev -m pwa --port 9303",
    "build": "quasar build -m pwa",
    "build:docker": "docker build -t vipr-wallet .",
    "postinstall": "quasar prepare",
    "coverage": "vitest run --coverage",
    "test:setup": "bash scripts/setup_test_shell.sh",
    "test:unit:ui": "vitest --ui",
    "test:unit:ci": "vitest run",
    "test:e2e": "pnpm run test:setup playwright test",
    "test:e2e:headed": "playwright test --headed",
    "typecheck": "exec vue-tsc --noEmit",
    "typecheck:pwa": "exec tsc -p src-pwa/tsconfig.json --noEmit",
    "run-devimint": "pnpm run test:setup playwright test",
    "final-check": "pnpm format && pnpm lint && pnpm typecheck && pnpm typecheck:pwa && pnpm test:unit:ci"
  },
  "dependencies": {
    "@fedimint/core": "0.0.0-canary-50fca06f9c3a3dc13e16b2f3440e66e852dc0d35",
    "@fedimint/transport-web": "0.0.0-canary-50fca06f9c3a3dc13e16b2f3440e66e852dc0d35",
    "@getalby/bitcoin-connect": "^3.12.2",
    "@getalby/lightning-tools": "^8.1.0",
    "@nostr-dev-kit/ndk": "^3.0.3",
    "@quasar/extras": "^1.18.0",
    "@vueuse/core": "^14.2.1",
    "bech32": "^2.0.0",
    "consola": "^3.4.2",
    "js-confetti": "^0.13.1",
    "qrcode.vue": "^3.8.1",
    "qrloop": "^1.4.1",
    "quasar": "^2.19.3",
    "register-service-worker": "^1.7.2",
    "uuid": "^13.0.0",
    "vue": "^3.5.32",
    "vue-qrcode-reader": "^5.7.3",
    "vue-router": "5.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@pinia/testing": "^1.0.3",
    "@playwright/test": "1.58.2",
    "@quasar/app-vite": "2.6.0",
    "@quasar/cli": "^4.0.0",
    "@quasar/vite-plugin": "^1.11.0",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.5.0",
    "eslint": "10.2.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.5.0",
    "happy-dom": "20.9.0",
    "lighthouse": "^13.1.0",
    "pinia": "^3.0.4",
    "prettier": "^3.8.2",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.8",
    "vite-plugin-checker": "^0.12.0",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.4",
    "vue-tsc": "^3.2.6",
    "workbox-build": "^7.4.0",
    "workbox-cacheable-response": "^7.4.0",
    "workbox-core": "^7.4.0",
    "workbox-expiration": "^7.4.0",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "workbox-strategies": "^7.4.0"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "bufferutil",
      "es5-ext",
      "esbuild",
      "utf-8-validate"
    ],
    "overrides": {
      "http-proxy-middleware": "^3.0.5",
      "@rollup/plugin-terser": "1.0.0"
    }
  }
}
